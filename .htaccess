# Draft redirect file for Apache. Final rules should be confirmed with the current server files.
DirectoryIndex index.html index.php

RewriteEngine On

# Future production URL design uses /cases/ as the M&A deal list.
# Keep the previous preview path working if someone has already bookmarked it.
Redirect 301 /market/ /cases/

# Preserve existing root-managed services if they exist on the server.
RewriteRule ^ai-satei/ - [L]

